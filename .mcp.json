{
    "mcpServers": {
        "petstore-mcp-stdio": {
            "type": "local",
            "command": "uv",
            "args": [
                "run",
                "petstore-mcp"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "PETSTORE_MCP_API_BASE_URL": "http://localhost:8000",
                "PETSTORE_MCP_API_KEY": "change-me",
                "PETSTORE_MCP_LOG_LEVEL": "DEBUG"
            },
            "tools": [
                "*"
            ]
        },
        "petstore-mcp-http": {
            "type": "http",
            "url": "http://127.0.0.1:8765/mcp",
            "tools": [
                "*"
            ]
        }
    }
}